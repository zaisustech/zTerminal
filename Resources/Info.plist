<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>zTerminal</string>
    <key>CFBundleDisplayName</key>
    <string>zTerminal</string>
    <key>CFBundleIdentifier</key>
    <string>com.zterminal.app</string>
    <key>CFBundleExecutable</key>
    <string>zTerminal</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>NSHumanReadableCopyright</key>
    <string>© 2026 ZAISUS TECHNOLOGIES (OPC) PRIVATE LIMITED. All rights reserved.</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>

    <!-- Custom URL scheme used by Finder integration / script runner. -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.zterminal.open</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>zterminal</string>
            </array>
        </dict>
    </array>

    <!-- Markdown files open in the preview (Finder double-click / "Open With").
         Handled by AppDelegate.application(_:open:). -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>Markdown Document</string>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSHandlerRank</key>
            <string>Alternate</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>net.daringfireball.markdown</string>
                <string>public.markdown</string>
            </array>
        </dict>
    </array>
    <!-- Declare the markdown UTI (macOS doesn't ship one) so the document
         type above matches .md/.markdown files everywhere. -->
    <key>UTImportedTypeDeclarations</key>
    <array>
        <dict>
            <key>UTTypeIdentifier</key>
            <string>net.daringfireball.markdown</string>
            <key>UTTypeDescription</key>
            <string>Markdown Document</string>
            <key>UTTypeConformsTo</key>
            <array>
                <string>public.plain-text</string>
            </array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array>
                    <string>md</string>
                    <string>markdown</string>
                </array>
            </dict>
        </dict>
    </array>

    <!-- Services entry: right-click a selected folder -> "Open in zTerminal".
         The service provider still needs to be wired in code (see README). -->
    <key>NSServices</key>
    <array>
        <dict>
            <key>NSMenuItem</key>
            <dict>
                <key>default</key>
                <string>Open in zTerminal</string>
            </dict>
            <key>NSMessage</key>
            <string>openFolderInZTerminal</string>
            <key>NSPortName</key>
            <string>zTerminal</string>
            <key>NSSendFileTypes</key>
            <array>
                <string>public.folder</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
